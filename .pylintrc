# ═══════════════════════════════════════════════════════════════════════════════
#  mPES — Unified Pylint Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#  Last updated: 2026-02-26
#
#  Applies to all packages: PES, PES_Bayesian, PES_QLv2, PES_Transformer, utils.
#
#  Verified: all four main packages score 10.00/10 with this configuration
#  (pyright 0 errors, pylint 10.00/10 as of 2026-02-26).
#
#  CORRECTION STANDARD
#  ────────────────────
#  ✅ ENFORCED (must fix):
#     • Missing docstrings on public functions/classes        (C0116, C0115, C0114)
#     • Trailing whitespace / missing final newline           (C0303, C0304)
#     • Unused imports                                        (W0611)
#     • Unused variables / arguments                          (W0612, W0613)
#     • Import style (use 'from X import Y' over aliases)     (R0402)
#     • Redefined built-in names                              (W0622)
#     • Unreachable code                                      (W0101)
#     • Dangerous default mutable arguments                   (W0102)
#     • Bare 'except:' without exception type                 (E0001, W0702)
#     • Missing return statements                             (R1710)
#     • Duplicate keys in dict literal                        (W0109)
#     • Unnecessary pass statement                            (W0107)
#
#  ⚠️  SUPPRESSED (framework noise / project conventions):
#     • Naming: PascalCase variables are project convention
#     • Complexity: scientific/RL code is inherently complex
#     • Framework: Gym/Keras/TF require non-standard patterns
#     • Style: minor preferences that don't affect correctness
# ═══════════════════════════════════════════════════════════════════════════════

[MAIN]
# Directories to skip entirely
ignore=__pycache__,outputs,inputs,.git

# Parallelise analysis (0 = use all CPUs)
jobs=0

# Minimum confidence level for messages (HIGH = fewer false positives)
confidence=HIGH,CONTROL_FLOW,INFERENCE,INFERENCE_FAILURE,UNDEFINED

# Load plugins (none required — keep lean)
load-plugins=

[FORMAT]
# 120-char hard limit — enforced across all packages
max-line-length=120

# Standard 4-space indentation (PEP 8)
indent-string='    '

# Maximum blank lines at end of file
max-module-lines=2000

[BASIC]
# Module names: allow snake_case and UPPER_CASE (for CONFIG.py)
module-rgx=[a-zA-Z_][a-zA-Z0-9_]*$

# Function/method names: allow snake_case (enforce)
function-rgx=[a-z_][a-z0-9_]{1,50}$|main$

# Variable names: allow snake_case AND PascalCase (project convention)
variable-rgx=[a-zA-Z_][a-zA-Z0-9_]{0,50}$

# Argument names: allow snake_case AND PascalCase (project convention)
argument-rgx=[a-zA-Z_][a-zA-Z0-9_]{0,50}$

# Constant names: allow UPPER_CASE and _private (module-level singletons)
const-rgx=[a-zA-Z_][a-zA-Z0-9_]{0,50}$

# Attribute names: allow both styles
attr-rgx=[a-zA-Z_][a-zA-Z0-9_]{0,50}$

# Class names: PascalCase
class-rgx=[A-Z_][a-zA-Z0-9]+$

# Good variable names (short names used in scientific code)
good-names=i,j,k,n,x,y,z,e,f,o,p,q,s,t,v,w,I,H,Q,R,T,B,M,N,lr,tf,np,ax,df,fn,mu,_

[MESSAGES CONTROL]
disable=
    # ── Naming (handled by [BASIC] regexes above) ──────────────
    invalid-name,                    # C0103: regexes above are the standard
    disallowed-name,                 # C0104: 'bar','e' used in scientific code

    # ── Complexity (scientific / RL code is inherently complex) ─
    too-many-locals,                 # R0914: RL training loops
    too-many-statements,             # R0915: experiment main functions
    too-many-branches,               # R0912: environment step logic
    too-many-positional-arguments,   # R0917: Gym/Keras constructors
    too-many-arguments,              # R0913: same
    too-many-return-statements,      # R0911: state machines
    too-many-instance-attributes,    # R0902: Gym env + model classes
    too-many-ancestors,              # R0901: Gym/Keras inheritance chains
    too-many-nested-blocks,          # R1702: nested experiment loops
    too-few-public-methods,          # R0903: config / data classes

    # ── Framework patterns (Gym / Keras / TensorFlow) ──────────
    abstract-method,                 # W0223: Gym Env / Keras Layer stubs
    arguments-differ,                # W0221: Keras/Gym method overrides
    attribute-defined-outside-init,  # W0201: Gym env.reset() sets attrs
    no-member,                       # E1101: TF/Keras dynamic attributes

    # ── Intentional code patterns ───────────────────────────────
    fixme,                           # W0511: FIXME/TODO/XXX are work notes
    duplicate-code,                  # R0801: shared patterns across modules
    global-statement,                # W0603: module-level singletons
    global-variable-not-assigned,    # W0602: global read-only access
    broad-exception-caught,          # W0718: defensive loading/fallbacks
    import-outside-toplevel,         # C0415: conditional/deferred imports
    wrong-import-order,              # C0411: os.environ must precede TF
    wrong-import-position,           # C0413: same as above
    wildcard-import,                 # W0401: from . import * in __init__

    # ── Minor style (not worth enforcing project-wide) ─────────
    line-too-long,                   # C0301: use max-line-length as guide
    multiple-statements,             # C0321: compact one-liners OK
    superfluous-parens,              # C0325: extra parens for readability
    consider-using-with,             # R1732: file handles for logging
    unspecified-encoding,            # W1514: consistent open() usage
    consider-using-f-string,         # C0209: .format() acceptable
    f-string-without-interpolation,  # W1309: template strings OK
    format-string-without-interpolation, # W1310: same
    singleton-comparison,            # C0121: done == True is Gym idiom
    super-with-arguments,            # R1725: explicit super() OK
    no-else-continue,                # R1724
    no-else-return,                  # R1705
    consider-using-enumerate,        # C0200
    unnecessary-comprehension,       # R1721
    unnecessary-lambda-assignment,   # C3001
    use-dict-literal,                # R1735
    consider-using-from-import,      # R0402

# ── ENFORCED (these remain ENABLED — violations MUST be fixed) ──
# C0116 missing-function-docstring   → add docstrings to public functions
# C0303 trailing-whitespace          → remove trailing spaces
# C0304 missing-final-newline        → add newline at EOF
# W0107 unnecessary-pass             → remove empty pass after docstring
# W0611 unused-import                → remove dead imports
# W0612 unused-variable              → remove or prefix with _
# W0613 unused-argument              → remove or prefix with _
# W0622 redefined-builtin            → never shadow builtins
# W0101 unreachable                  → remove dead code
# W0102 dangerous-default-value      → use None instead of mutable default
# W0702 bare-except                  → specify exception type
# R1710 inconsistent-return-stmts    → all paths must return consistently
# W0109 duplicate-key                → no duplicate dict keys
# E0001 syntax-error                 → code must parse

[TYPECHECK]
# Avoid false positives on dynamic TF/Keras/numpy/optuna members
generated-members=numpy.*,np.*,tf.*,tensorflow.*,optuna.*,keras.*
ignored-modules=tensorflow,tensorflow.keras,keras
ignored-classes=tensorflow.keras.Model,tensorflow.keras.layers.Layer

[SIMILARITIES]
# Require ≥12 duplicate lines before flagging (scientific code repeats)
min-similarity-lines=12
ignore-comments=yes
ignore-docstrings=yes
ignore-imports=yes

[DESIGN]
# Relaxed thresholds (still enforced as warnings)
max-args=10
max-locals=25
max-returns=8
max-branches=20
max-statements=100
max-parents=16
max-attributes=15

[IMPORTS]
# Known third-party libraries (avoid false positives)
known-third-party=numpy,tensorflow,keras,matplotlib,optuna,scipy,statsmodels,gymnasium,pygame